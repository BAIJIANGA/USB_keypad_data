 106:USER/CherryUSB/fsdev/usb_dc_fsdev.c ****     USB->ISTR = 0U;
 107:USER/CherryUSB/fsdev/usb_dc_fsdev.c **** 
 108:USER/CherryUSB/fsdev/usb_dc_fsdev.c ****     /* switch-off device */
 109:USER/CherryUSB/fsdev/usb_dc_fsdev.c ****     USB->CNTR = (uint16_t)(USB_CNTR_FRES | USB_CNTR_PDWN);
 110:USER/CherryUSB/fsdev/usb_dc_fsdev.c **** 
